{% extends template('page-layout-main') %}

{% define data = {
    supplier: _view.supplier | default({}),
} %}

{% block title %}{{ data.supplier.name | default('Supplier') }}{% endblock %}

{% block content %}
    <div class="container">
        <p><a href="{{ url('supplier-list') }}">&larr; {{ 'Back to list' | trans }}</a></p>

        {% if data.supplier.idSupplier is not defined %}
            <div class="alert alert-warning">
                {{ 'Supplier not found.' | trans }}
            </div>
        {% else %}
            <div class="card">
                <div class="card-header">
                    <h1>{{ data.supplier.name }}</h1>
                </div>
                <div class="card-body">
                    <table class="table table-borderless">
                        <tbody>
                            <tr>
                                <th>{{ 'ID' | trans }}</th>
                                <td>{{ data.supplier.idSupplier }}</td>
                            </tr>
                            <tr>
                                <th>{{ 'Description' | trans }}</th>
                                <td>{{ data.supplier.description | default('N/A') }}</td>
                            </tr>
                            <tr>
                                <th>{{ 'Email' | trans }}</th>
                                <td>{{ data.supplier.email | default('N/A') }}</td>
                            </tr>
                            <tr>
                                <th>{{ 'Phone' | trans }}</th>
                                <td>{{ data.supplier.phone | default('N/A') }}</td>
                            </tr>
                            <tr>
                                <th>{{ 'Status' | trans }}</th>
                                <td>
                                    {% if data.supplier.status == 1 %}
                                        <span class="badge badge-success">{{ 'Active' | trans }}</span>
                                    {% else %}
                                        <span class="badge badge-secondary">{{ 'Inactive' | trans }}</span>
                                    {% endif %}
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        {% endif %}
    </div>
{% endblock %}
