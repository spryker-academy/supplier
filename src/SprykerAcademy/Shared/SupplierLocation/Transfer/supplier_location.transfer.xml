<?xml version="1.0"?>
<transfers xmlns="spryker:transfer-01"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="spryker:transfer-01 http://static.spryker.com/transfer-01.xsd">

    <transfer name="SupplierLocation">
        <property name="idSupplierLocation" type="int" />
        <property name="idSupplier" type="int" />
        <property name="city" type="string" />
        <property name="country" type="string" />
        <property name="address" type="string" />
        <property name="zipCode" type="string" />
        <property name="isDefault" type="bool" />
        <property name="supplier" type="Supplier"/>
    </transfer>

    <transfer name="SupplierLocationCriteria">
        <property name="idSupplierLocation" type="int"/>
        <property name="idSupplier" type="int"/>
        <property name="city" type="string"/>
        <property name="country" type="string"/>
    </transfer>

    <transfer name="SupplierLocationCollection">
        <property name="supplierLocations" singular="supplierLocation" type="SupplierLocation[]"/>
        <property name="pagination" type="Pagination"/>
    </transfer>

    <transfer name="SupplierLocationResponse">
        <property name="supplierLocation" type="SupplierLocation"/>
        <property name="isSuccessful" type="bool"/>
        <property name="errors" singular="error" type="string[]"/>
    </transfer>

</transfers>
